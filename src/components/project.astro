---
type Project = {
    name: string
    description: string
    url: string
}

type Props = {
    projects: Project[]
    title?: string
    description?: string
}

const {
    projects,
    title = 'Highlights',
    description = "I've worked on many private services and applications, but these are some of the public ones.",
} = Astro.props
---

{projects.length > 0 && (
    <section class="mb-12" id="projects">
        <h2 class="ibm-plex-mono-semibold text-xl mb-4">{title}</h2>
        <p class="text-sm ibm-plex-mono-regular text-gray-400 mb-6">
            {description}
        </p>
        <div class="">
            {projects.map((project) => (
                <div class="p-4  hover:bg-gray-100/5 rounded-lg
                transition duration-300">
                    <a href={project.url} target="_blank" rel="noreferrer" >
                        <h3 class="text-md ibm-plex-mono-semibold bg-transparent text-default">{project.name}</h3>
                    </a>
                    <a href={project.url} target="_blank" rel="noreferrer">
                        <p class="text-sm ibm-plex-mono-regular bg-transparent mt-2 text-gray-400 leading-6 !italic">{project.description}</p>
                    </a>
                </div>
            ))}
        </div>
    </section>
)}
